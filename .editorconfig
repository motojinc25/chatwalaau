# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

# 4 space indentation
[*.{py}]
indent_style = space
indent_size = 4

# 2 space indentation
[*.{js,jsx,mjs,ts,tsx,json,y{a,}ml,html}]
indent_style = space
indent_size = 2

# Markdown files should not have trailing whitespace
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# Makefiles should use tabs for indentation
[Makefile]
indent_style = tab
