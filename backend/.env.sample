# ==========================================
# ChatWalaʻau Configuration
# The localhost AI Agent Runtime -- Chat UI, Tools, RAG, and MCP in one pip install.
# ==========================================

# >> Web SPA Authentication
# Optional ID/PW + opaque session cookie lane for cloud-deployed SPAs.
# Leave AUTH_USERNAME empty to disable.
# When set, AUTH_PASSWORD_HASH is required;
# verify_api_key accepts EITHER Bearer API_KEY OR a valid session cookie.
# The strict /v1/responses path is Bearer-only.
# Generate the hash with: `chatwalaau hash-password`
#AUTH_USERNAME=admin
#AUTH_PASSWORD_HASH=scrypt$N=16384,r=8,p=1$<base64-salt>$<base64-hash>
#AUTH_SESSION_TTL_SECONDS=86400
#AUTH_COOKIE_SECURE=auto
#AUTH_COOKIE_NAME=chatwalaau_session
# Session-cookie SameSite policy: lax (default) | strict | none. Use the default "lax"
# behind a TLS-terminating tunnel / reverse proxy (e.g. Microsoft Dev Tunnels) -- "strict"
# can drop the cookie on cross-site entry and cause a login redirect loop. "none" requires
# (and forces) a Secure cookie.
#AUTH_COOKIE_SAMESITE=lax
# Persist session token DIGESTS (sha256, never the raw token) across a backend restart.
# Only active when AUTH_USERNAME is set. false = in-memory only.
#AUTH_SESSION_PERSIST=true
# Where the digest store lives. Never contains a raw token. Delete the file to log every
# user out; rotating AUTH_PASSWORD_HASH has the same effect.
#AUTH_SESSION_STORE_PATH=.auth/session_tokens.json

# >> [Azure OpenAI] Endpoint (e.g., https://your-resource.openai.azure.com/)
#AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# >> [Azure OpenAI] Authentication
# Decision matrix (highest precedence wins):
#   AZURE_OPENAI_API_KEY set
#     -> api-key lane (works on localhost and Azure cloud,
#        bypasses Entra ID entirely)
#   AZURE_OPENAI_API_KEY unset + AZURE_CREDENTIAL_MODE=cli (default)
#     -> AzureCliCredential() / az login
#        (localhost development, personal box)
#   AZURE_OPENAI_API_KEY unset + AZURE_CREDENTIAL_MODE=managed-identity
#     -> ManagedIdentityCredential()
#        (Azure App Service, Container Apps, AKS, Functions, VM;
#        assign the Managed Identity the "Cognitive Services OpenAI
#        User" role on the Azure OpenAI resource)
#   AZURE_OPENAI_API_KEY unset + AZURE_CREDENTIAL_MODE=default
#     -> DefaultAzureCredential(exclude_interactive_browser_credential=True)
#        (auto-discovery: env -> WorkloadIdentity -> ManagedIdentity ->
#        SharedToken -> AzureCli -> ...)
# One INFO log line per process announces the active lane at first use.
#AZURE_OPENAI_API_KEY=
#AZURE_CREDENTIAL_MODE=cli

# >> [Azure OpenAI] Tenant ID
# Required for tenant pinning under cli / default credential modes;
# ignored by managed-identity mode and the api-key lane.
#AZURE_TENANT_ID=

# >> [Models] Model Offering Catalog (REQUIRED for chat -- PRP-0113)
# Model routing is managed EXCLUSIVELY by the Model Offering Catalog (a JSONC
# file). The legacy per-provider model env vars (AZURE_OPENAI_MODELS /
# ANTHROPIC_MODELS / OPENAI_MODELS / FOUNDRY_MODELS, ANTHROPIC_HOSTING,
# MODEL_MAX_CONTEXT_TOKENS, and the per-provider chat endpoint/key vars) were
# REMOVED. A non-demo deployment with no catalog still BOOTS (with a startup
# warning, so the in-app Model Settings screen stays reachable); chat is
# unavailable until you author a catalog (DEMO_MODE=true runs without one).
#
# MODEL_OFFERINGS_FILE points at the catalog (default model_offerings.jsonc,
# resolved against the working directory). Author it with
# `chatwalaau models add|edit|remove` (offline), the in-app Model Settings
# screen (hot-reloads without a restart), or by hand. Full guide:
# assets/docs/guides/model-providers.md
#MODEL_OFFERINGS_FILE=model_offerings.jsonc
#
# Each offering self-describes its provider / model_ref / endpoint / base_url /
# hosting / context_window and references any api-key env var by NAME
# (api_key_env) -- secrets are NEVER written in the file. One endpoint fronting
# several model families is just several offerings; direct + Foundry Claude
# coexist via per-offering "hosting". Example model_offerings.jsonc:
#
#   {
#     "offerings": [
#       { "id": "gpt-5.5", "provider": "azure-openai", "model_ref": "gpt-5.5",
#         "endpoint": "${AZURE_OPENAI_ENDPOINT}", "default": true,
#         "context_window": 1050000 },
#       { "id": "claude-opus-4-8", "provider": "anthropic", "hosting": "direct",
#         "model_ref": "claude-opus-4-8", "api_key_env": "ANTHROPIC_API_KEY",
#         "context_window": 1050000 },
#       { "id": "gpt-5.1", "provider": "openai", "model_ref": "gpt-5.1",
#         "api_key_env": "OPENAI_API_KEY" },
#       // Optional single embeddings offering (enables RAG; PRP-0114):
#       { "id": "embed", "provider": "azure-openai", "operations": ["embeddings"],
#         "model_ref": "text-embedding-3-small" },
#       // Optional single image offering (enables image generation; PRP-0114).
#       // "image_defaults" are the operator output-behavior defaults; each is
#       // overridable per session (the Image button) and per call (the model):
#       { "id": "image", "provider": "azure-openai", "operations": ["image"],
#         "model_ref": "gpt-image-2", "api_version": "2025-04-01-preview",
#         "image_defaults": { "size": "auto", "quality": "auto", "format": "png",
#                             "background": "auto" } }
#     ]
#   }
#
# A chat offering's context_window sets its context-window limit; when omitted it
# defaults to 128000. An azure-openai offering may omit "endpoint"/api_key_env to
# reuse the shared AZURE_OPENAI_ENDPOINT + Azure credential lanes above; an
# embeddings/image offering may likewise omit them (api_version defaults:
# embeddings 2024-10-21, image 2025-04-01-preview). At most one embeddings and one
# image offering are allowed; "image_defaults" is valid ONLY on an image offering.
# The api-key env vars an offering references (e.g. ANTHROPIC_API_KEY,
# OPENAI_API_KEY) are plain .env values you set as needed -- there is no fixed
# schema for them.

# >> [Models] Web search country for country-specific results (default: US)
# Applies to the OpenAI hosted web search tool (azure-openai AND openai
# providers). Anthropic models get the separate
# AnthropicClient.get_web_search_tool() hosted tool, which has no country
# parameter (see assets/docs/guides/model-providers.md).
#WEB_SEARCH_COUNTRY=US

# >> [Anthropic] Generation / reasoning
# ANTHROPIC_MAX_TOKENS caps thinking + text COMBINED. Anthropic Opus 4.7/4.8 use
# adaptive thinking + an effort level (output_config.effort; the deprecated
# budget_tokens mechanism is NOT used). Because thinking and the answer share the
# cap, the backend scales it PER EFFORT (low 8192 / medium 16000 / high 32000 /
# xhigh 48000 / max 64000) so high-effort thinking cannot starve the answer down
# to one token. This setting is a FLOOR -- set it higher than a tier to enlarge
# that tier's budget (e.g. for a model with a larger output window); it never
# lowers a tier. The effort itself is selectable per message in the UI; its
# default (xhigh) is backend-served -- there is no env var for it.
#ANTHROPIC_MAX_TOKENS=8192

# >> [OpenAI] API key (OPENAI_API_KEY)
# Retained shared value (PRP-0113): consumed by image generation and the RAG
# embedder plain-OpenAI path, and it is a valid target for a chat offering's
# "api_key_env": "OPENAI_API_KEY". The public OpenAI API authenticates by API
# key only (no Entra ID lane).
#OPENAI_API_KEY=sk-...

# >> [Prompt Caching] Provider-agnostic input-token cost reduction
# When enabled (default) each provider marks its large, stable per-call prefix
# (system prompt + tool schemas) as cacheable, so it is billed once and re-read
# cheaply on the many model calls of one turn (e.g. a coding tool loop).
# Output-transparent: model outputs are identical with it on or off; only
# billing / latency change. Set false to restore the pre-PRP-0080 request shape.
#   - azure-openai: caching is AUTOMATIC for prefixes >= 1024 tokens (no change).
#   - anthropic: injects cache_control on the system block + tools array.
#PROMPT_CACHE_ENABLED=true

# Anthropic prompt-cache TTL: 5m (default, GA) or 1h (extended cache; adds the
# extended-cache-ttl-2025-04-11 beta). Unknown -> 5m. azure-openai ignores it.
#ANTHROPIC_PROMPT_CACHE_TTL=5m

# >> [Azure OpenAI] Speech-to-Text model deployment name (default: none)
# Supported model families:
#   REST audio.transcriptions path:
#     - whisper, whisper-1                       (classic Whisper)
#     - gpt-4o-transcribe, gpt-4o-mini-transcribe
#   Realtime API WebSocket path:
#     - gpt-realtime-whisper
# Transport is auto-selected by name (substring "realtime" -> Realtime).
# Override with WHISPER_MODEL_KIND below if the name does not match
# convention but you want to force a specific transport.
#WHISPER_DEPLOYMENT_NAME=gpt-realtime-whisper

# >> [Azure OpenAI] STT Model Kind override (default: auto)
# auto      : infer transport from WHISPER_DEPLOYMENT_NAME (substring rule)
# rest      : force REST audio.transcriptions path
# realtime  : force Realtime API WebSocket path
#WHISPER_MODEL_KIND=auto

# >> [Azure OpenAI] Realtime API WebSocket connection deployment (default: empty)
# AZURE DEVIATION (Microsoft Learn `realtime-audio-websockets`):
# The Realtime WebSocket URL `?model=` query MUST name a VOICE Realtime
# deployment (gpt-realtime / gpt-realtime-mini / gpt-realtime-1.5).
# `gpt-realtime-whisper` is a TRANSCRIPTION-ONLY model and CANNOT be
# used as the connection model -- putting it on the URL returns
# HTTP 400 at handshake.
# When using `gpt-realtime-whisper`:
#   1) Deploy a voice Realtime model in Microsoft Foundry (gpt-realtime
#      or gpt-realtime-mini).
#   2) Set WHISPER_DEPLOYMENT_NAME=gpt-realtime-whisper
#      (transcription model, goes into session payload).
#   3) Set WHISPER_REALTIME_CONNECTION_DEPLOYMENT=gpt-realtime
#      (voice model, goes into URL ?model=).
# When using a self-connecting Realtime model (e.g. gpt-4o-realtime-*):
#   Leave this empty -- WHISPER_DEPLOYMENT_NAME is used for both the
#   URL and the session payload.
#WHISPER_REALTIME_CONNECTION_DEPLOYMENT=gpt-realtime-2

# >> [Azure OpenAI] Realtime API version (default: empty = GA path)
# Only consumed when the STT lane resolves to "realtime".
# Two URL shapes are supported (Microsoft Learn realtime-audio-websockets):
#   Empty (default) -> GA path:
#     wss://<host>/openai/v1/realtime?model=<deployment>
#     (REQUIRED for gpt-realtime-whisper and any 2025-08-28+ Realtime model)
#   Non-empty       -> Preview path:
#     wss://<host>/openai/realtime?api-version=<v>&deployment=<d>
#     (only for legacy models such as gpt-4o-realtime-preview)
# Mixing GA path with api-version= or preview path with model= returns
# HTTP 400 at handshake.
#AZURE_OPENAI_REALTIME_API_VERSION=

# >> [Azure OpenAI] Realtime input audio sample rate in Hz (default: 24000)
# Allowed: 16000, 24000. The browser webm/Opus stream is resampled to
# this rate server-side before being sent via input_audio_buffer.append.
#WHISPER_REALTIME_AUDIO_RATE=24000

# >> [Image Generation] configured via the Model Offering Catalog (PRP-0114).
# Image generation (generate_image / edit_image / mask edit) is enabled by adding
# ONE offering with operations: ["image"] to model_offerings.jsonc (see the catalog
# example above). The former IMAGE_DEPLOYMENT_NAME / IMAGE_API_VERSION / IMAGE_SIZE /
# IMAGE_QUALITY / IMAGE_FORMAT / IMAGE_COMPRESSION / IMAGE_BACKGROUND env vars were
# REMOVED: the deployment is offering.model_ref, the API version is
# offering.api_version, and the output-behavior defaults are the offering's optional
# "image_defaults" block (still overridable per session via the Image button and per
# call by the model). No image offering -> image generation is simply off.

# >> [RAG Embeddings] configured via the Model Offering Catalog (PRP-0114).
# RAG (rag_search + rag-ingest) requires ONE offering with operations:
# ["embeddings"] in model_offerings.jsonc (see the catalog example above). The former
# EMBEDDING_DEPLOYMENT_NAME env var was REMOVED (it is offering.model_ref). CHROMA_DIR
# and the RAG_* pipeline knobs below are NOT model routing and are retained. No
# embeddings offering -> RAG is unavailable with an actionable message.

# >> Text-to-Speech provider selection (default: elevenlabs)
# Which provider backs POST /api/tts (the speaker / download buttons):
#   elevenlabs     : ElevenLabs SDK (default; uses the keys below)
#   azure-realtime : Azure OpenAI Realtime voice model (e.g. gpt-realtime-2)
#                    over a WebSocket session; PCM16 output is encoded to MP3.
# Unknown values fall back to elevenlabs.
#TTS_PROVIDER=azure-realtime

# >> Text-to-Speech ElevenLabs API Key and model/voice selection (default: none)
# Consumed when TTS_PROVIDER=elevenlabs.
#ELEVENLABS_API_KEY=
#TTS_MODEL_ID=eleven_multilingual_v2
#TTS_VOICE_ID=

# >> Text-to-Speech Azure OpenAI Realtime settings (default: none)
# Consumed when TTS_PROVIDER=azure-realtime. Reuses AZURE_OPENAI_ENDPOINT,
# the credential lane above, and AZURE_OPENAI_REALTIME_API_VERSION
# (shared with the STT realtime lane: empty = GA path, non-empty = preview).
# Unlike gpt-realtime-whisper (STT), gpt-realtime-2 is itself a VOICE model,
# so the deployment name goes directly into the URL ?model= -- no separate
# connection deployment is needed.
#TTS_REALTIME_DEPLOYMENT=gpt-realtime-2
#TTS_REALTIME_VOICE=alloy
#TTS_REALTIME_AUDIO_RATE=24000

# >> HTTPS / TLS for LAN access with Secure Context
# Generate certificates with mkcert: mkcert <your-ip> localhost 127.0.0.1
# Application host (default: 127.0.0.1)
#APP_HOST=0.0.0.0
#APP_SSL_CERTFILE=.certs/cert.pem
#APP_SSL_KEYFILE=.certs/key.pem

# >> Application Port (default: 8000)
#APP_PORT=8000

# >> Debug mode for FastAPI docs/redoc/openapi (default: false)
#APP_DEBUG=false

# >> Show upstream Microsoft Agent Framework experimental warnings at startup (default: false)
# When false/unset, the MAF staged-feature lines such as
#   [HARNESS] MemoryStore is experimental ...
#   [SKILLS] SkillResource is experimental ...
# are hidden at startup. Set to true to restore them (debugging upstream behavior).
#SHOW_EXPERIMENTAL_WARNINGS=false

# >> Frontend dist directory (relative to Backend root, used by static file server, default: ../frontend/dist)
#FRONTEND_DIST=../frontend/dist

# >> CORS (comma-separated origins, default:http://localhost:5173)
#CORS_ALLOWED_ORIGINS=http://localhost:5173

# >> [API] Authentication (default: none)
# API_KEY is the unified Bearer token for:
#   - External-app access to /v1/responses (always required)
#   - Write endpoints (image edit, upload, MCP Apps RPC, sessions write,
#     templates write, TTS, STT) when the CLIENT connects from a
#     non-loopback address
# Same-machine clients (127.0.0.1, ::1, localhost) always bypass auth,
# even when APP_HOST=0.0.0.0 for LAN exposure.
#API_KEY=sk-chatwalaau-your-secret-key-here

# >> [API] Enforce Bearer API_KEY on write endpoints for non-loopback clients (default: true)
# Default true (fail-closed). Set to false only if an operator explicitly
# accepts unauthenticated LAN exposure.
#APP_REQUIRE_AUTH_ON_LAN=true

# >> [Storage] Session data directory (default: .sessions)
#SESSIONS_DIR=.sessions

# >> [Session] Auto chat title generation (default: truncate)
# How a new chat's sidebar title is set:
#   truncate (default) -- the leading ~100 characters of the first user message
#   llm                -- a background task summarizes the first user message + the
#                         first assistant reply into a concise title (post-turn,
#                         non-blocking; on failure the truncation title remains)
# The summarization model is assigned in model_offerings.jsonc via the `roles`
# block (roles.session_title); unset uses the session / default model. Set it with
# `chatwalaau models role set session_title <offering-id>` or Model Settings. AG-UI
# SPA sessions only in this release (API / DevUI / CLI keep the truncation title).
#SESSION_TITLE_MODE=truncate

# >> [Storage] File Upload directory (default: .uploads)
#UPLOAD_DIR=.uploads

# >> [Chat] Attached PDF handling (PRP-0116, UDR-0099)
# How an attached PDF is given to the LLM as context (like an image). Values:
#   "auto" (default): native document attachment for providers that support it
#     (azure-openai / openai / foundry, sent as a Responses input_file); text
#     extraction for others (e.g. anthropic, whose connector drops non-image data).
#   "native": always attach the raw PDF (only for a supporting provider).
#   "text": always extract the PDF text (safe fallback if a deployment rejects input_file).
#PDF_ATTACH_MODE=auto
# Character cap on TEXT-extracted PDF content (the text / anthropic path). Text
# beyond it is truncated with a marker. Scanned / image-only PDFs (no extractable
# text) fall back to a RAG-ingest note.
#PDF_INLINE_MAX_CHARS=20000

# >> [Session] Chat import bundle size cap in bytes (default: 26214400 = 25 MiB)
# Maximum accepted size of an uploaded chat import bundle (.zip) for the sidebar
# Import action. Bounds the compressed upload; the import path also enforces an
# internal uncompressed-total and entry-count cap (zip-bomb defense).
#SESSION_IMPORT_MAX_BYTES=26214400

# >> [Storage] Temporary Chat quarantine retention in days (default: 30)
# Ephemeral "incognito-style" chats are stored in a separate .temporary/ directory
# (never shown in the sidebar or search) for safety / abuse monitoring, then
# auto-deleted after this many days. The Temporary Chat feature itself has NO
# enable/disable switch (always available); this retention period is the only knob.
# Set to 0 to keep quarantine entries indefinitely.
#TEMPORARY_CHAT_RETENTION_DAYS=30

# >> [Storage] Agent Skills (file-based SKILL.md packages, default: .skills)
#SKILLS_DIR=.skills

# >> [Agent] Declarative Agents
# Folder of CUSTOM declarative agent YAML files (*.yaml / *.yml; nested folders
# allowed), discovered through a realpath jail rooted here. Empty (default) = no
# custom agents; only the bundled CORE agent exists and the runtime is unchanged.
# The active selection is in-memory only (a restart re-initializes to CORE) and is
# switched from the SPA. The YAML is a SPECIFICATION: ChatWalaʻau owns construction,
# credentials / connection in the YAML are ignored, and classic sampling parameters
# are rejected at activation (the models are reasoning-only). A YAML `tools:` block, when
# present, restricts that agent to a SUBSET of the available tools (PRP-0117). GUI authoring
# (Create / Edit in the Declarative Agents modal) is enabled only when this points at a
# WRITABLE directory.
#DECLARATIVE_AGENTS_DIR=.agents

# >> [Declarative Workflows] YAML-defined multi-agent orchestration (PRP-0118, UDR-0101).
# A `kind: Workflow` entity is discovered from the SAME DECLARATIVE_AGENTS_DIR tree as
# `kind: Prompt` agents (dispatched by `kind`); unset DECLARATIVE_AGENTS_DIR = no workflows.
# WORKFLOW_MAX_ITERATIONS is a runaway-loop / cost guard capping workflow supersteps
# (the YAML `maxTurns` still applies as a smaller fallback). Default: 100.
#WORKFLOW_MAX_ITERATIONS=100

# >> [Storage] Prompt Templates (file-based JSON templates, default: .templates)
#TEMPLATES_DIR=.templates

# >> [Agent] Global Agent Identity (file-based)
# The agent's persona / tone / base posture lives in the FIXED file
# `.agent/IDENTITY.md` (the path is NOT an environment variable). It is the first
# block of every agent's system prompt, auto-created from a built-in default on
# first start. Edit it in the Memory Management portal (or on disk) to customize
# the persona, or delete it to regenerate the default; on a read-only filesystem
# the in-memory default is used. IDENTITY_CHAR_LIMIT (default 4000) bounds the file
# when saved via the Memory Editor (CTR-0166), keeping the "backup + cap" guard
# uniform with USER_CHAR_LIMIT / MEMORY_CHAR_LIMIT.
#IDENTITY_CHAR_LIMIT=4000

# >> [Agent] User Preference Memory (file-based)
# A small durable user profile lives in the FIXED file `.agent/USER.md` and is
# rendered as the Memory Block (Prompt Assembly slot #2, after the Identity). The
# agent maintains it inline via a memory tool; the per-session snapshot is frozen
# at session start. USER_PROFILE_ENABLED toggles the whole feature (default true).
# USER_CHAR_LIMIT bounds the curated entries (default 1375); over-limit additions are rejected with a hint to
# consolidate. The file path itself is fixed (not an env var).
#USER_PROFILE_ENABLED=true
#USER_CHAR_LIMIT=1375

# >> [Agent] User Memory Background Extraction
# When enabled, a background task distills conversations into durable user
# preferences and merges them into `.agent/USER.md` through the SAME guarded write
# as the inline tool (secret/PII filter + USER_CHAR_LIMIT cap + backup). Requires
# USER_PROFILE_ENABLED=true. Default false = byte-for-byte prior behavior. The
# pass runs at most once every USER_MEMORY_EXTRACTION_EVERY_N_TURNS new user turns
# (default 4); below that it is a cheap no-op. The extraction model is assigned in
# model_offerings.jsonc (roles.user_memory_extraction); unset uses the session /
# default model. temp_ chats and DEMO_MODE never extract.
#USER_MEMORY_EXTRACTION=false
#USER_MEMORY_EXTRACTION_EVERY_N_TURNS=4

# >> [Agent] Agent Curated Memory
# A SECOND built-in file memory `.agent/MEMORY.md` -- the agent's own curated
# notebook of durable facts ABOUT THE WORK (environment, project conventions, tool
# quirks, operating rules), stored as `§`-delimited entries and rendered as the
# <agent-memory> block (Prompt Assembly slot #2b, after the User Profile). The agent
# maintains it inline via the manage_memory tool, and any chat turn can be given a
# thumbs-up (like) to run a lightweight background reconcile pass over that turn.
# AGENT_MEMORY_ENABLED toggles the whole feature (default true, matching
# USER_PROFILE_ENABLED); false restores pre-PRP-0100 behavior byte-for-byte. An
# EMPTY MEMORY.md injects NO block, so a fresh install is unchanged until a first
# entry is curated. MEMORY_CHAR_LIMIT bounds the serialized memory body (default
# 2200); an over-cap add/modify is rejected with a hint to remove/consolidate.
# The background reconcile model for the like pass is assigned in model_offerings.jsonc
# (roles.agent_memory_curation); unset uses the session / default model. The file path is
# fixed (not an env var). temp_ chats and DEMO_MODE never curate.
#AGENT_MEMORY_ENABLED=true
#MEMORY_CHAR_LIMIT=2200

# >> [Debug] Prompt Dump (default: off)
# When on, each chat run writes the fully assembled system prompt (Identity + User
# Profile + Agent Memory + capability guidance), the input messages, and the agent's
# TOOL SURFACE to a timestamped file under PROMPT_DUMP_DIR, so you can inspect the
# exact prompt state per run. The tool surface lists every built-in function, MCP
# server/tool, and Skill -- including the ones that are NOT there, with the reason
# (settings / allowlist / mcp override / skills override / not connected) -- so you
# can see why a tool is missing and which screen owns the gate. The prompt CONTENT
# goes only to the file; logs show metadata only (path, sizes, injection flags,
# tool digest and counts). Best-effort and non-blocking; default false = no files.
#PROMPT_DUMP_ENABLED=false
#PROMPT_DUMP_DIR=.prompts

# >> [Storage][RAG] Vector database directory (shared between Backend and pipeline ingest, default: .chroma)
#CHROMA_DIR=.chroma

# >> Pipeline Job subsystem (in-process data-processing jobs, e.g. RAG ingest)
# ON by default (unlike CRON_ENABLED). When false the /api/pipeline/* endpoints 404,
# the sidebar Pipelines icon is hidden, and the manage_pipeline agent tool is not
# registered. Pipeline jobs run only curated in-process job types (no shell, no
# CODING_ENABLED). PIPELINE_JOBS_DIR replaces the removed BATCH_JOBS_DIR; per-job JSON
# plus an output/{job_id}/{run_id}/ run-history tree (run meta + captured log) live there.
#PIPELINE_ENABLED=true
#PIPELINE_JOBS_DIR=.pipeline
#PIPELINE_OUTPUT_MAX_BYTES=1048576
#PIPELINE_MAX_CONCURRENT_JOBS=2

# >> MCP Integration (default: mcp_servers.jsonc)
# Two-tier resolution: the runtime first tries this filename, then
# falls back to the bundled mcp_servers.default.jsonc in the same
# directory. Set this to an explicit empty value to disable MCP.
# JSONC format: `//` and `/* */` comments are stripped before parse.
# See: https://modelcontextprotocol.io
#MCP_CONFIG_FILE=mcp_servers.jsonc

# >> Slash Commands (default: commands.jsonc)
# Optional operator override for the slash command registry. The four built-in
# commands (/help, /prompt, /skill, /model) are code-backed and always available,
# so this is OPTIONAL. Two-tier resolution: the runtime tries this filename, then
# falls back to a bundled commands.default.jsonc in the same directory; an explicit
# empty value disables loading the operator file. JSONC: `//` and `/* */` comments
# are stripped before parse.
#COMMANDS_CONFIG_FILE=commands.jsonc

# >> MCP Apps (interactive UI in chat via sandboxed iframe, default: 8081)
# Sandbox proxy runs on a separate port for origin isolation.
# Activated automatically when MCP tools declare _meta.ui resources.
#MCP_APPS_SANDBOX_PORT=8081

# >> [RAG] Collection name for document storage and search (default: default)
#RAG_COLLECTION_NAME=default

# >> [RAG] Number of search results returned by rag_search tool (default: 5)
#RAG_TOP_K=5

# >> [Pipeline][RAG] RAG ingest chunk parameters (read by the rag-ingest job type)
#RAG_CHUNK_SIZE=1500
#RAG_CHUNK_OVERLAP=300
#RAG_CHUNK_MIN_SIZE=300

# >> [DevUI] Development debug UI for agent testing (default: false)
#DEVUI_ENABLED=false
#DEVUI_PORT=8080
#DEVUI_AUTH_ENABLED=true
#DEVUI_AUTH_TOKEN=
#DEVUI_TRACING=false
#DEVUI_MODE=developer
#DEVUI_DISABLE_MCP=true
#DEVUI_DISABLE_RAG=true

# >> [Coding] MAF native coding tools (default: false)
#CODING_ENABLED=false
#CODING_WORKSPACE_DIR=
#CODING_BASH_TIMEOUT=30
#CODING_MAX_OUTPUT_CHARS=100000
#CODING_MAX_TURNS=50
#CODING_FILE_READ_MAX_BYTES=1048576

# >> [File Explorer] Human-facing VSCode-style file browse/edit over the coding
# workspace (default: false). OFF unless FILE_EXPLORER_ENABLED; every file operation
# ADDITIONALLY requires CODING_ENABLED=true (and CODING_WORKSPACE_DIR set). Reuses the
# CTR-0031 realpath jail; mutating endpoints are auth-gated (loopback exempt).
#FILE_EXPLORER_ENABLED=false
# Max size (bytes) a file may be opened/saved at in the editor (default 5 MiB).
#FILE_EXPLORER_MAX_FILE_BYTES=5242880
# Cap on entries returned per directory level (default 1000).
#FILE_EXPLORER_MAX_TREE_ENTRIES=1000
# Download path (separate from the editor open/save cap above). Upper bound (bytes) on a
# single-file download and on a folder ZIP total uncompressed size (default 100 MiB).
#FILE_EXPLORER_MAX_DOWNLOAD_BYTES=104857600
# Max number of files included in a folder ZIP (default 5000).
#FILE_EXPLORER_MAX_DOWNLOAD_ENTRIES=5000
# Upload path. FILE_EXPLORER_MAX_UPLOAD_BYTES caps the TOTAL bytes across all files
# in one POST /api/workspace/upload (default 100 MiB); FILE_EXPLORER_MAX_UPLOAD_FILES caps the
# file count (a folder upload sends one file per descendant; default 500).
#FILE_EXPLORER_MAX_UPLOAD_BYTES=104857600
#FILE_EXPLORER_MAX_UPLOAD_FILES=500

# >> [Cron] File-execution scheduler (default: false). The whole feature is OFF
# unless CRON_ENABLED. Cron runs are script-only inside the coding workspace and
# ADDITIONALLY require CODING_ENABLED=true (and CODING_WORKSPACE_DIR set).
#CRON_ENABLED=false
# Tick interval in seconds (clamped to 5..3600).
#CRON_TICK_SECONDS=60
# Directory of per-job JSON files; run logs go under <dir>/output/.
#CRON_JOBS_DIR=.cron
# Missed-run tolerance: lateness beyond this fast-forwards without running
# (clamped to 120..7200).
#CRON_GRACE_WINDOW_SECONDS=120
# IANA timezone for cron expressions; empty = system local (e.g. Pacific/Honolulu).
#CRON_TIMEZONE=
# Per-run subprocess wall-clock timeout in seconds.
#CRON_RUN_TIMEOUT_SECONDS=900
# Cap (bytes) per captured stdout/stderr log file.
#CRON_OUTPUT_MAX_BYTES=1048576

# >> [Microsoft Teams] First external chat-channel integration (default: false).
# Converse with the agent from a Teams personal chat, group chat, or channel.
# The whole feature is OFF unless TEAMS_ENABLED: when false the
# Teams router is not mounted and the SDK is not constructed (byte-for-byte unchanged).
# Local dev needs a public tunnel (Microsoft Dev Tunnels default; ngrok / cloudflared)
# and a registered bot -- see assets/docs/guides/teams-tunnel-setup.md and
# assets/docs/guides/teams-bot-registration.md. Inbound is authenticated by Microsoft
# Bot Framework JWT (not API_KEY); Object-ID allow-list adds per-sender authorization.
#TEAMS_ENABLED=false
# Bot/app CLIENT_ID (Entra application/client id); the JWT audience.
#TEAMS_APP_ID=
# CLIENT_SECRET (Entra client secret). Secret.
#TEAMS_APP_PASSWORD=
# Entra TENANT_ID.
#TEAMS_TENANT_ID=
# Comma-separated Microsoft Entra ID Object IDs (aadObjectId) allowed to use the bot.
# Leave blank to allow everyone (no restriction).
#TEAMS_ALLOWED_USERS=
# Inbound path mounted and registered as the bot messaging endpoint (default below).
#TEAMS_MESSAGING_ENDPOINT_PATH=/api/teams/messages
# Max characters per outbound Teams message chunk (Teams size-limit guard).
#TEAMS_MAX_REPLY_CHARS=25000

# >> [Webhook] Inbound Webhook Gateway (default: false). A separate external-boundary
# capability. The whole feature is OFF unless
# WEBHOOK_ENABLED: when false the /api/webhook/* ingress + /api/webhooks/* management
# routers 404, the maintenance scheduler does not run, the sidebar icon is hidden, the
# manage_webhook tool is not registered, and the teams-meeting job type is not registered.
# The first source is Microsoft Graph (Teams meeting transcripts). Local dev needs a
# public tunnel -- see assets/docs/guides/webhook-msgraph-setup.md.
#WEBHOOK_ENABLED=false
# Public base path for inbound notifications; sources mount at <base>/{source}.
#WEBHOOK_INGRESS_BASE_PATH=/api/webhook
# Webhook store directory (per-source enable/disable + receipt records + subscriptions).
#WEBHOOK_STORE_DIR=.webhooks
# Cap per captured receipt record body in bytes (0 = unbounded).
#WEBHOOK_RECEIPT_MAX_BYTES=1048576
# clientState shared secret used to validate Microsoft Graph notifications (HMAC-safe).
#MSGRAPH_WEBHOOK_CLIENT_STATE=
# Public, tunnel-reachable notification URL given to Graph at subscribe time.
#MSGRAPH_WEBHOOK_NOTIFICATION_URL=
# Graph resource to subscribe (e.g. communications/onlineMeetings/getAllTranscripts).
#MSGRAPH_WEBHOOK_RESOURCE=
# Subscription renewal interval in hours (default 12; MUST be shorter than the resource
# max expiry). Auto-renewal runs only while CRON_ENABLED (UDR-0075 D8).
#MSGRAPH_SUBSCRIPTION_RENEW_HOURS=12
# Optional source CIDR allowlist (comma-separated; empty = off).
#MSGRAPH_WEBHOOK_ALLOWED_CIDRS=
# Optional resource allowlist (comma-separated; empty = off).
#MSGRAPH_WEBHOOK_ALLOWED_RESOURCES=

# >> [Graph] Microsoft Graph app-only credentials (dedicated namespace).
# Used by the webhook gateway to manage subscriptions and fetch meetings/transcripts.
# May point to the same Entra app registration as TEAMS_* (with Graph application
# permissions added); kept separate so the two trust models do not get conflated. Teams
# transcript access ALSO requires a Teams Application Access Policy (see the setup guide).
#GRAPH_TENANT_ID=
#GRAPH_CLIENT_ID=
#GRAPH_CLIENT_SECRET=
#GRAPH_BASE_URL=https://graph.microsoft.com/v1.0

# >> [Teams Meeting Pipeline] Teams meeting transcript summarization.
# The teams-meeting pipeline job (registered when WEBHOOK_ENABLED + PIPELINE_ENABLED)
# writes a summary JSON into the coding workspace (CODING_WORKSPACE_DIR jail).
# Output subdir within the workspace (default: meeting-summaries).
#TEAMS_MEETING_OUTPUT_DIR=meeting-summaries
# The summary model is assigned in model_offerings.jsonc (roles.meeting_summary);
# unset uses the session / default model.
# A transcript artifact is often not ready right when a meeting ends; the fetch stage
# polls for it up to this many seconds before failing (default 600 = 10 min).
#TEAMS_MEETING_TRANSCRIPT_MAX_WAIT_SECONDS=600
# Poll interval while waiting for the transcript artifact (seconds; default 30).
#TEAMS_MEETING_TRANSCRIPT_POLL_SECONDS=30

# >> [Ontology] Ontology Concept Modeling (default: false). Rule-based concept models as
# RDF knowledge graphs (Turtle file SSOT + catalog.json, read-only SPARQL, NL -> SPARQL,
# React Flow editor, session-common query_ontology agent tool). The whole feature is OFF
# unless ONTOLOGY_ENABLED: when false the /api/ontology endpoints 404, the sidebar
# Ontology icon is hidden, and the query_ontology tool is not registered.
#ONTOLOGY_ENABLED=false
# Folder holding catalog.json + one Turtle file per ontology (created on demand).
#ONTOLOGY_DIR=.ontologies
# Upload/import and save size cap in bytes (default 10 MiB).
#ONTOLOGY_MAX_FILE_BYTES=10485760
# Cap on triples serialized into a query_ontology tool answer (context-window guard).
#ONTOLOGY_TOOL_MAX_TRIPLES=200
# The NL -> SPARQL completion model is assigned in model_offerings.jsonc
# (roles.ontology_nl); unset uses the default model.

# >> [CLI Client] CLI client configuration
# Base URL for CLI client subcommands (default: http://localhost:8000)
# API key for CLI client authentication (reuses API_KEY if not set)
#CHATWALAAU_URL=http://localhost:8000
#CHATWALAAU_API_KEY=

# >> [Demo Mode] Cloud demo without LLM cost
# DEMO_MODE=true replaces every metered external provider (chat, STT, TTS,
# image generation, RAG embedding) with an in-process deterministic dummy.
# Default false preserves the byte-for-byte live behavior.
# Single toggle -- per-provider opt-ins are not supported.
# Weather (Open-Meteo) STAYS LIVE because it's free and key-less.
# Use with AUTH_USERNAME or API_KEY: DEMO_MODE never relaxes API Authentication Dependency.
# Comma-separated demo model list for the model selector UI.
# Only consumed when DEMO_MODE=true.
# Per-token streaming delay in milliseconds (range 0..500). Drives the
# perceived "live typing" effect in the SPA chat UI.
#DEMO_MODE=true
#DEMO_MODELS=gpt-5.5,gpt-5.4,claude-opus-4-8,claude-opus-4-7
#DEMO_LATENCY_MS=40

# >> [Agent Harness] Conversation Compaction
# Allowed values: none / sliding-window (default) / selective-tool-call / tool-result.
# - sliding-window keeps the trailing N message groups; preserve_system retains the system block.
# - selective-tool-call / tool-result are tool-call-aware variants.
# - none disables compaction (the agent will hard-fail at the model's context window).
# COMPACTION_KEEP_LAST_GROUPS is also re-used as keep_last_tool_call_groups for the tool-call-aware variants. Range 1..32.
#COMPACTION_STRATEGY=sliding-window
#COMPACTION_KEEP_LAST_GROUPS=4
#COMPACTION_PRESERVE_SYSTEM=true

# >> [Agent Harness] Tool Approval Flow
# Allowed modes:
# - skip   -- No tool is wrapped; the SPA renders PermissionsDisabledBanner.
# - auto   -- (default) Tools in TOOL_APPROVAL_REQUIRE_LIST require approval.
# - always -- Every non-readonly tool requires approval.
# TOOL_APPROVAL_REQUIRE_LIST is the comma-separated list of tool __name__s (default: bash_execute,file_write).
# TOOL_APPROVAL_TIMEOUT_SEC bounds how long the parked AG-UI stream waits for POST /api/tool-approval (range 5..86400).
# TOOL_APPROVAL_ARG_MAX_CHARS caps per-field argument preview length in the AG-UI CUSTOM event (the full value still reaches the tool on approval).
# TOOL_APPROVAL_MAX_ITERATIONS bounds the human-interactive approval rounds per turn (default 33, range 1..1000). Rounds resolved from a "approve for session" grant do NOT count against it.
# TOOL_APPROVAL_ABSOLUTE_MAX_ITERATIONS is the runaway-agent backstop counting EVERY round incl. session-cached ones (default 200, range 1..100000, must be >= TOOL_APPROVAL_MAX_ITERATIONS).
#TOOL_APPROVAL_MODE=auto
#TOOL_APPROVAL_REQUIRE_LIST=bash_execute,file_write
#TOOL_APPROVAL_TIMEOUT_SEC=300
#TOOL_APPROVAL_ARG_MAX_CHARS=4096
#TOOL_APPROVAL_MAX_ITERATIONS=33
#TOOL_APPROVAL_ABSOLUTE_MAX_ITERATIONS=200
