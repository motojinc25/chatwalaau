# ==========================================
# ChatWalaʻau Configuration
# The localhost AI Agent Runtime -- Chat UI, Tools, RAG, and MCP in one pip install.
# ==========================================

# >> Web SPA Authentication
# Optional ID/PW + opaque session cookie lane for cloud-deployed SPAs.
# Leave AUTH_USERNAME empty to disable.
# When set, AUTH_PASSWORD_HASH is required;
# verify_api_key accepts EITHER Bearer API_KEY OR a valid session cookie.
# The strict /v1/responses path is Bearer-only.
# Generate the hash with: `chatwalaau hash-password`
#AUTH_USERNAME=admin
#AUTH_PASSWORD_HASH=scrypt$N=16384,r=8,p=1$<base64-salt>$<base64-hash>
#AUTH_SESSION_TTL_SECONDS=86400
#AUTH_COOKIE_SECURE=auto
#AUTH_COOKIE_NAME=chatwalaau_session

# >> [Azure OpenAI] Endpoint (e.g., https://your-resource.openai.azure.com/)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# >> [Azure OpenAI] Authentication
# Decision matrix (highest precedence wins):
#   AZURE_OPENAI_API_KEY set
#     -> api-key lane (works on localhost and Azure cloud,
#        bypasses Entra ID entirely)
#   AZURE_OPENAI_API_KEY unset + AZURE_CREDENTIAL_MODE=cli (default)
#     -> AzureCliCredential() / az login
#        (localhost development, personal box)
#   AZURE_OPENAI_API_KEY unset + AZURE_CREDENTIAL_MODE=managed-identity
#     -> ManagedIdentityCredential()
#        (Azure App Service, Container Apps, AKS, Functions, VM;
#        assign the Managed Identity the "Cognitive Services OpenAI
#        User" role on the Azure OpenAI resource)
#   AZURE_OPENAI_API_KEY unset + AZURE_CREDENTIAL_MODE=default
#     -> DefaultAzureCredential(exclude_interactive_browser_credential=True)
#        (auto-discovery: env -> WorkloadIdentity -> ManagedIdentity ->
#        SharedToken -> AzureCli -> ...)
# One INFO log line per process announces the active lane at first use.
#AZURE_OPENAI_API_KEY=
#AZURE_CREDENTIAL_MODE=cli

# >> [Azure OpenAI] Tenant ID
# Required for tenant pinning under cli / default credential modes;
# ignored by managed-identity mode and the api-key lane.
#AZURE_TENANT_ID=

# >> [Azure OpenAI] Models
# Comma-separated deployment names. First entry is the default model.
# Single model is valid (e.g., AZURE_OPENAI_MODELS=gpt-4o).
AZURE_OPENAI_MODELS=gpt-5.5,gpt-5.4,gpt-4o

# >> [Azure OpenAI] Reasoning Effort
# Per-model format: name:effort pairs (only listed models get reasoning).
# Models NOT listed do not send reasoning.effort parameter.
# Valid effort values: low, medium, high, xhigh
REASONING_EFFORT=gpt-5.5:medium,gpt-5.4:medium

# >> [Azure OpenAI] Model Context Window
# Per-model format: name:tokens pairs, comma-separated.
# Single integer fallback applies to all models (e.g., MODEL_MAX_CONTEXT_TOKENS=128000).
# | Model     | max_context_tokens |
# | gpt-4o    |             128000 |
# | gpt-5.4   |            1050000 |
# | gpt-5.5   |            1050000 |
MODEL_MAX_CONTEXT_TOKENS=gpt-5.5:1050000,gpt-5.4:1050000,gpt-4o:128000

# >> [Azure OpenAI] Models web search tool uses for country-specific results (default: US)
#WEB_SEARCH_COUNTRY=US

# >> [Azure OpenAI] Speech-to-Text model deployment name (default: none)
# Supported model families:
#   REST audio.transcriptions path:
#     - whisper, whisper-1                       (classic Whisper)
#     - gpt-4o-transcribe, gpt-4o-mini-transcribe
#   Realtime API WebSocket path:
#     - gpt-realtime-whisper
# Transport is auto-selected by name (substring "realtime" -> Realtime).
# Override with WHISPER_MODEL_KIND below if the name does not match
# convention but you want to force a specific transport.
#WHISPER_DEPLOYMENT_NAME=gpt-realtime-whisper

# >> [Azure OpenAI] STT Model Kind override (default: auto)
# auto      : infer transport from WHISPER_DEPLOYMENT_NAME (substring rule)
# rest      : force REST audio.transcriptions path
# realtime  : force Realtime API WebSocket path
#WHISPER_MODEL_KIND=auto

# >> [Azure OpenAI] Realtime API WebSocket connection deployment (default: empty)
# AZURE DEVIATION (Microsoft Learn `realtime-audio-websockets`):
# The Realtime WebSocket URL `?model=` query MUST name a VOICE Realtime
# deployment (gpt-realtime / gpt-realtime-mini / gpt-realtime-1.5).
# `gpt-realtime-whisper` is a TRANSCRIPTION-ONLY model and CANNOT be
# used as the connection model -- putting it on the URL returns
# HTTP 400 at handshake.
# When using `gpt-realtime-whisper`:
#   1) Deploy a voice Realtime model in Azure Foundry (gpt-realtime
#      or gpt-realtime-mini).
#   2) Set WHISPER_DEPLOYMENT_NAME=gpt-realtime-whisper
#      (transcription model, goes into session payload).
#   3) Set WHISPER_REALTIME_CONNECTION_DEPLOYMENT=gpt-realtime
#      (voice model, goes into URL ?model=).
# When using a self-connecting Realtime model (e.g. gpt-4o-realtime-*):
#   Leave this empty -- WHISPER_DEPLOYMENT_NAME is used for both the
#   URL and the session payload.
#WHISPER_REALTIME_CONNECTION_DEPLOYMENT=gpt-realtime-2

# >> [Azure OpenAI] Realtime API version (default: empty = GA path)
# Only consumed when the STT lane resolves to "realtime".
# Two URL shapes are supported (Microsoft Learn realtime-audio-websockets):
#   Empty (default) -> GA path:
#     wss://<host>/openai/v1/realtime?model=<deployment>
#     (REQUIRED for gpt-realtime-whisper and any 2025-08-28+ Realtime model)
#   Non-empty       -> Preview path:
#     wss://<host>/openai/realtime?api-version=<v>&deployment=<d>
#     (only for legacy models such as gpt-4o-realtime-preview)
# Mixing GA path with api-version= or preview path with model= returns
# HTTP 400 at handshake.
#AZURE_OPENAI_REALTIME_API_VERSION=

# >> [Azure OpenAI] Realtime input audio sample rate in Hz (default: 24000)
# Allowed: 16000, 24000. The browser webm/Opus stream is resampled to
# this rate server-side before being sent via input_audio_buffer.append.
#WHISPER_REALTIME_AUDIO_RATE=24000

# >> [Azure OpenAI] Image Generation model deployment name (default: none)
#IMAGE_DEPLOYMENT_NAME=gpt-image-2

# >> [Azure OpenAI] Embedding model deployment name (default: text-embedding-3-small)
#EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-small

# >> Text-to-Speech provider selection (default: elevenlabs)
# Which provider backs POST /api/tts (the speaker / download buttons):
#   elevenlabs     : ElevenLabs SDK (default; uses the keys below)
#   azure-realtime : Azure OpenAI Realtime voice model (e.g. gpt-realtime-2)
#                    over a WebSocket session; PCM16 output is encoded to MP3.
# Unknown values fall back to elevenlabs.
#TTS_PROVIDER=azure-realtime

# >> Text-to-Speech ElevenLabs API Key and model/voice selection (default: none)
# Consumed when TTS_PROVIDER=elevenlabs.
#ELEVENLABS_API_KEY=
#TTS_MODEL_ID=eleven_multilingual_v2
#TTS_VOICE_ID=

# >> Text-to-Speech Azure OpenAI Realtime settings (default: none)
# Consumed when TTS_PROVIDER=azure-realtime. Reuses AZURE_OPENAI_ENDPOINT,
# the credential lane above, and AZURE_OPENAI_REALTIME_API_VERSION
# (shared with the STT realtime lane: empty = GA path, non-empty = preview).
# gpt-realtime-2 is itself a VOICE model, so the deployment name goes
# directly into the URL ?model= -- no separate connection deployment.
#TTS_REALTIME_DEPLOYMENT=gpt-realtime-2
#TTS_REALTIME_VOICE=alloy
#TTS_REALTIME_AUDIO_RATE=24000

# >> HTTPS / TLS for LAN access with Secure Context
# Generate certificates with mkcert: mkcert <your-ip> localhost 127.0.0.1
# Application host (default: 127.0.0.1)
#APP_HOST=0.0.0.0
#APP_SSL_CERTFILE=.certs/cert.pem
#APP_SSL_KEYFILE=.certs/key.pem

# >> Application Port (default: 8000)
#APP_PORT=8000

# >> Debug mode for FastAPI docs/redoc/openapi (default: false)
#APP_DEBUG=false

# >> Show upstream Microsoft Agent Framework experimental warnings at startup (default: false)
# When false/unset, the MAF staged-feature lines such as
#   [HARNESS] MemoryStore is experimental ...
#   [SKILLS] SkillResource is experimental ...
# are hidden at startup. Set to true to restore them (debugging upstream behavior).
#SHOW_EXPERIMENTAL_WARNINGS=false

# >> Frontend dist directory (relative to Backend root, used by static file server, default: ../frontend/dist)
#FRONTEND_DIST=../frontend/dist

# >> CORS (comma-separated origins, default:http://localhost:5173)
#CORS_ALLOWED_ORIGINS=http://localhost:5173

# >> [API] Authentication (default: none)
# API_KEY is the unified Bearer token for:
#   - External-app access to /v1/responses (always required)
#   - Write endpoints (image edit, upload, MCP Apps RPC, sessions write,
#     templates write, TTS, STT) when the CLIENT connects from a
#     non-loopback address
# Same-machine clients (127.0.0.1, ::1, localhost) always bypass auth,
# even when APP_HOST=0.0.0.0 for LAN exposure.
#API_KEY=sk-chatwalaau-your-secret-key-here

# >> [API] Enforce Bearer API_KEY on write endpoints for non-loopback clients (default: true)
# Default true (fail-closed). Set to false only if an operator explicitly
# accepts unauthenticated LAN exposure.
#APP_REQUIRE_AUTH_ON_LAN=true

# >> [Storage] Session data directory (default: .sessions)
#SESSIONS_DIR=.sessions

# >> [Storage] File Upload directory (default: .uploads)
#UPLOAD_DIR=.uploads

# >> [Storage] Agent Skills (file-based SKILL.md packages, default: .skills)
#SKILLS_DIR=.skills

# >> [Storage] Prompt Templates (file-based JSON templates, default: .templates)
#TEMPLATES_DIR=.templates

# >> [Storage][RAG] Vector database directory (shared between Backend and Batch server, default: .chroma)
#CHROMA_DIR=.chroma

# >> [Storage][Batch MCP] Batch jobs directory (default: .jobs)
#BATCH_JOBS_DIR=.jobs

# >> MCP Integration (default: mcp_servers.jsonc)
# Two-tier resolution: the runtime first tries this filename, then
# falls back to the bundled mcp_servers.default.jsonc in the same
# directory. Set this to an explicit empty value to disable MCP.
# JSONC format: `//` and `/* */` comments are stripped before parse.
# See: https://modelcontextprotocol.io
#MCP_CONFIG_FILE=mcp_servers.jsonc

# >> MCP Apps (interactive UI in chat via sandboxed iframe, default: 8081)
# Sandbox proxy runs on a separate port for origin isolation.
# Activated automatically when MCP tools declare _meta.ui resources.
#MCP_APPS_SANDBOX_PORT=8081

# >> [RAG] Collection name for document storage and search (default: default)
#RAG_COLLECTION_NAME=default

# >> [RAG] Number of search results returned by rag_search tool (default: 5)
#RAG_TOP_K=5

# >> [Batch MCP] RAG chunk parameters
#RAG_CHUNK_SIZE=1500
#RAG_CHUNK_OVERLAP=300
#RAG_CHUNK_MIN_SIZE=300

# >> [DevUI] Development debug UI for agent testing (default: false)
#DEVUI_ENABLED=false
#DEVUI_PORT=8080
#DEVUI_AUTH_ENABLED=true
#DEVUI_AUTH_TOKEN=
#DEVUI_TRACING=false
#DEVUI_MODE=developer
#DEVUI_DISABLE_MCP=true
#DEVUI_DISABLE_RAG=true

# >> [Coding] MAF native coding tools (default: false)
#CODING_ENABLED=false
#CODING_WORKSPACE_DIR=
#CODING_BASH_TIMEOUT=30
#CODING_MAX_OUTPUT_CHARS=100000
#CODING_MAX_TURNS=50
#CODING_FILE_READ_MAX_BYTES=1048576

# >> [CLI Client] CLI client configuration
# Base URL for CLI client subcommands (default: http://localhost:8000)
# API key for CLI client authentication (reuses API_KEY if not set)
#CHATWALAAU_URL=http://localhost:8000
#CHATWALAAU_API_KEY=

# >> [Demo Mode] Cloud demo without LLM cost
# DEMO_MODE=true replaces every metered external provider (chat, STT, TTS,
# image generation, RAG embedding) with an in-process deterministic dummy.
# Default false preserves the byte-for-byte live behavior.
# Single toggle -- per-provider opt-ins are not supported.
# Weather (Open-Meteo) STAYS LIVE because it's free and key-less.
# Use with AUTH_USERNAME or API_KEY: DEMO_MODE never relaxes API Authentication Dependency.
# Comma-separated demo model list for the model selector UI.
# Only consumed when DEMO_MODE=true.
# Per-token streaming delay in milliseconds (range 0..500). Drives the
# perceived "live typing" effect in the SPA chat UI.
#DEMO_MODE=true
#DEMO_MODELS=gpt-4o-demo,gpt-4o-mini-demo,o3-demo
#DEMO_LATENCY_MS=40
